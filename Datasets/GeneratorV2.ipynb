# Cellule 1 : Imports et configuration
import json
import numpy as np
import pandas as pd
from datetime import datetime, timedelta
from typing import Dict, Any, Optional
import warnings
warnings.filterwarnings('ignore')


# Cellule 2 : Classe principale du générateur
class AdvancedDatasetGenerator:
    """Générateur de datasets avancé avec corrélations, dépendances et imperfections."""
    
    def __init__(self, rules_path: str):
        with open(rules_path, 'r', encoding='utf-8') as f:
            self.rules = json.load(f)
        
        self.metadata = self.rules.get('metadata', {})
        self.num_records = self.metadata.get('num_records', 100)
        self.seed = self.metadata.get('seed', None)
        
        # Initialisation du générateur aléatoire pour reproductibilité
        self.rng = np.random.default_rng(self.seed)
        self.dataset = {}
        
    def _get_rng(self):
        """Retourne le générateur aléatoire."""
        return self.rng
    
    def _generate_single_variable(self, name: str, config: Dict) -> np.ndarray:
        """Génère une variable selon sa configuration."""
        var_type = config['type']
        rng = self._get_rng()
        size = self.num_records
        
        if var_type == 'continuous':
            return self._generate_continuous(config, size, rng)
        elif var_type == 'discrete':
            return self._generate_discrete(config, size, rng)
        elif var_type == 'categorical':
            return self._generate_categorical(config, size, rng)
        elif var_type == 'datetime':
            return self._generate_datetime(config, size, rng)
        else:
            raise ValueError(f"Type de variable inconnu: {var_type}")
    
    def _generate_continuous(self, config: Dict, size: int, rng) -> np.ndarray:
        """Génère une variable continue selon différentes distributions."""
        dist = config.get('distribution', 'normal')
        
        if dist == 'normal':
            return rng.normal(config['mean'], config['stddev'], size)
        elif dist == 'lognormal':
            return rng.lognormal(config['mean'], config['stddev'], size)
        elif dist == 'exponential':
            return rng.exponential(config['scale'], size)
        elif dist == 'uniform':
            return rng.uniform(config['low'], config['high'], size)
        elif dist == 'beta':
            return rng.beta(config['a'], config['b'], size)
        elif dist == 'gamma':
            return rng.gamma(config['shape'], config['scale'], size)
        else:
            raise ValueError(f"Distribution continue inconnue: {dist}")
    
    def _generate_discrete(self, config: Dict, size: int, rng) -> np.ndarray:
        """Génère une variable discrète."""
        dist = config.get('distribution', 'binomial')
        
        if dist == 'binomial':
            return rng.binomial(config['n'], config['p'], size)
        elif dist == 'poisson':
            return rng.poisson(config['lam'], size)
        elif dist == 'geometric':
            return rng.geometric(config['p'], size)
        else:
            raise ValueError(f"Distribution discrète inconnue: {dist}")
    
    def _generate_categorical(self, config: Dict, size: int, rng) -> np.ndarray:
        """Génère une variable catégorielle avec probabilités."""
        categories = config['categories']
        probs = config.get('probabilities', None)
        if probs is not None:
            probs = np.array(probs)
            probs = probs / probs.sum()  # Normalisation
        return rng.choice(categories, size=size, p=probs)
    
    def _generate_datetime(self, config: Dict, size: int, rng) -> np.ndarray:
        """Génère des dates avec tendance temporelle."""
        start = datetime.strptime(config['start'], '%Y-%m-%d')
        end = datetime.strptime(config['end'], '%Y-%m-%d')
        total_seconds = int((end - start).total_seconds())
        
        trend = config.get('trend', 'uniform')
        
        if trend == 'uniform':
            offsets = rng.integers(0, total_seconds, size)
        elif trend == 'increasing':
            # Distribution biaisée vers la fin
            u = rng.random(size)
            offsets = (u ** 2 * total_seconds).astype(int)
        elif trend == 'decreasing':
            u = rng.random(size)
            offsets = ((1 - u ** 2) * total_seconds).astype(int)
        else:
            offsets = rng.integers(0, total_seconds, size)
        
        dates = [start + timedelta(seconds=int(o)) for o in offsets]
        return np.array(dates)
    
    def _apply_correlations(self):
        """Applique les corrélations entre variables (loi normale multivariée)."""
        correlations = self.rules.get('correlations', {})
        
        for group_name, group_config in correlations.items():
            variables = group_config['variables']
            cov_matrix = np.array(group_config['covariance_matrix'])
            
            # Vérification que les variables existent
            for var in variables:
                if var not in self.dataset:
                    raise ValueError(f"Variable {var} non trouvée pour la corrélation {group_name}")
            
            # Génération multivariée
            means = np.zeros(len(variables))
            samples = self.rng.multivariate_normal(means, cov_matrix, self.num_records)
            
            # Remplacement des variables corrélées
            for i, var in enumerate(variables):
                # On ajoute la moyenne originale si elle existe
                var_config = self.rules['variables'][var]
                if 'mean' in var_config:
                    self.dataset[var] = samples[:, i] + var_config['mean']
                else:
                    self.dataset[var] = samples[:, i]
    
    def _evaluate_formula(self, formula: str) -> np.ndarray:
        """Évalue une formule mathématique en utilisant les variables du dataset."""
        # Création d'un namespace avec les variables
        namespace = {name: pd.Series(values) for name, values in self.dataset.items()}
        namespace['np'] = np
        namespace['abs'] = np.abs
        namespace['log'] = np.log
        namespace['exp'] = np.exp
        namespace['sqrt'] = np.sqrt
        
        try:
            result = pd.eval(formula, local_dict=namespace, engine='python')
            return np.array(result)
        except Exception as e:
            raise ValueError(f"Erreur lors de l'évaluation de la formule '{formula}': {e}")
    
    def _generate_noise(self, noise_config: Dict) -> np.ndarray:
        """Génère du bruit selon la configuration."""
        noise_type = noise_config.get('type', 'normal')
        size = self.num_records
        rng = self._get_rng()
        
        if noise_type == 'normal':
            return rng.normal(noise_config['mean'], noise_config['stddev'], size)
        elif noise_type == 'uniform':
            return rng.uniform(noise_config['low'], noise_config['high'], size)
        else:
            raise ValueError(f"Type de bruit inconnu: {noise_type}")
    
    def _apply_dependencies(self):
        """Calcule les variables dépendantes (dérivées ou conditionnelles)."""
        dependencies = self.rules.get('dependencies', {})
        
        for var_name, config in dependencies.items():
            dep_type = config['type']
            
            if dep_type == 'derived':
                values = self._evaluate_formula(config['formula'])
                if 'noise' in config:
                    values = values + self._generate_noise(config['noise'])
                self.dataset[var_name] = values
                
            elif dep_type == 'conditional':
                values = np.zeros(self.num_records)
                default_applied = np.zeros(self.num_records, dtype=bool)
                
                for rule in config['rules']:
                    if 'condition' in rule:
                        # Évaluation de la condition
                        condition = self._evaluate_formula(rule['condition'])
                        mask = condition.astype(bool)
                        
                        # Génération de la valeur selon la distribution
                        value_dist = rule['value_distribution']
                        if value_dist['type'] == 'constant':
                            values[mask] = value_dist['value']
                        else:
                            # Génération pour les lignes satisfaisant la condition
                            sub_size = mask.sum()
                            sub_values = self._generate_single_variable(
                                var_name + '_temp', 
                                {**value_dist, 'type': value_dist.get('type', 'continuous')}
                            )[:sub_size] if sub_size > 0 else []
                            values[mask] = sub_values
                            
                    elif 'default' in rule:
                        # Valeur par défaut pour les lignes non encore traitées
                        default_mask = ~default_applied
                        default_dist = rule['default']
                        if default_dist['type'] == 'constant':
                            values[default_mask] = default_dist['value']
                        default_applied[default_mask] = True
                
                self.dataset[var_name] = values
    
    def _generate_target(self):
        """Génère la variable cible pour le ML supervisé."""
        target_config = self.rules.get('target', None)
        if target_config is None:
            return
        
        values = self._evaluate_formula(target_config['formula'])
        
        # Ajout de bruit
        if 'noise' in target_config:
            values = values + self._generate_noise(target_config['noise'])
        
        # Transformation
        if 'transform' in target_config:
            transform = target_config['transform']
            if transform == 'abs':
                values = np.abs(values)
            elif transform == 'log':
                values = np.log(np.abs(values) + 1e-10)
            elif transform == 'sigmoid':
                values = 1 / (1 + np.exp(-values))
        
        # Classification binaire si demandé
        if target_config.get('type') == 'classification':
            threshold = target_config.get('threshold', 0.5)
            values = (values > threshold).astype(int)
        
        self.dataset[target_config['name']] = values
    
    def _apply_data_quality(self):
        """Injecte des imperfections réalistes dans les données."""
        quality_config = self.rules.get('data_quality', {})
        df = pd.DataFrame(self.dataset)
        
        # Valeurs manquantes
        missing_config = quality_config.get('missing_values', {})
        for var_name, config in missing_config.items():
            rate = config['rate']
            mechanism = config.get('mechanism', 'MCAR')
            
            if mechanism == 'MCAR':
                # Totalement aléatoire
                mask = self.rng.random(self.num_records) < rate
                df.loc[mask, var_name] = np.nan
                
            elif mechanism == 'MAR':
                # Dépend d'une autre variable
                depends_on = config['depends_on']
                if depends_on in df.columns:
                    # Plus la valeur de depends_on est élevée, plus la probabilité de NaN est grande
                    probs = df[depends_on].values
                    if probs.dtype.kind in 'biufc':
                        probs = (probs - probs.min()) / (probs.max() - probs.min() + 1e-10)
                    else:
                        probs = np.ones(self.num_records) * 0.5
                    probs = probs * rate * 2  # Amplification
                    probs = np.clip(probs, 0, 1)
                    mask = self.rng.random(self.num_records) < probs
                    df.loc[mask, var_name] = np.nan
                    
            elif mechanism == 'MNAR':
                # Dépend de la valeur elle-même
                values = df[var_name].values
                if values.dtype.kind in 'biufc':
                    mask = np.abs(values) > np.percentile(np.abs(values[~np.isnan(values)]), 100 * (1 - rate))
                    df.loc[mask, var_name] = np.nan
        
        # Outliers
        outliers_config = quality_config.get('outliers', {})
        for var_name, config in outliers_config.items():
            rate = config['rate']
            method = config.get('method', 'gaussian_smear')
            
            if method == 'gaussian_smear':
                multiplier = config.get('multiplier', 5)
                num_outliers = int(self.num_records * rate)
                
                # Sécurité si le taux est trop petit pour générer au moins 1 outlier
                if num_outliers == 0:
                    continue 
                    
                outlier_indices = self.rng.choice(self.num_records, num_outliers, replace=False)
                
                # 👇 LA CORRECTION EST ICI : on ajoute .copy()
                values = df[var_name].values.copy() 
                
                mean_val = np.nanmean(values)
                std_val = np.nanstd(values)
                
                # Injection des outliers
                values[outlier_indices] = mean_val + self.rng.normal(0, std_val * multiplier, num_outliers)
                df[var_name] = values
        
        # Label noise (pour variables catégorielles)
        label_noise_config = quality_config.get('label_noise', {})
        for var_name, config in label_noise_config.items():
            rate = config['rate']
            num_noisy = int(self.num_records * rate)
            noisy_indices = self.rng.choice(self.num_records, num_noisy, replace=False)
            
            categories = self.rules['variables'][var_name]['categories']
            new_labels = self.rng.choice(categories, num_noisy)
            df.loc[df.index[noisy_indices], var_name] = new_labels
        
        self.dataset = {col: df[col].values for col in df.columns}
    
    def _export(self):
        """Exporte le dataset au format spécifié."""
        df = pd.DataFrame(self.dataset)
        output_format = self.metadata.get('output_format', 'csv')
        filename = self.metadata.get('output_filename', 'dataset.csv')
        
        if output_format == 'csv':
            df.to_csv(filename, index=False)
        elif output_format == 'parquet':
            df.to_parquet(filename, index=False)
        elif output_format == 'json':
            df.to_json(filename, orient='records', indent=2)
        else:
            raise ValueError(f"Format de sortie inconnu: {output_format}")
        
        return filename
    
    def generate(self) -> pd.DataFrame:
        """Orchestre la génération complète du dataset."""
        print("🚀 Génération du dataset en cours...")
        
        # 1. Génération des variables de base
        print("  📊 Génération des variables de base...")
        for var_name, config in self.rules.get('variables', {}).items():
            self.dataset[var_name] = self._generate_single_variable(var_name, config)
        
        # 2. Application des corrélations
        print("  🔗 Application des corrélations...")
        self._apply_correlations()
        
        # 3. Calcul des dépendances
        print("  🔀 Calcul des dépendances...")
        self._apply_dependencies()
        
        # 4. Génération de la cible
        print("  🎯 Génération de la variable cible...")
        self._generate_target()
        
        # 5. Injection des imperfections
        print("  🌧️  Injection des imperfections (missing values, outliers, noise)...")
        self._apply_data_quality()
        
        # 6. Export
        print("  💾 Export du dataset...")
        filename = self._export()
        
        df = pd.DataFrame(self.dataset)
        print(f"✅ Dataset généré avec succès : {filename}")
        print(f"   📏 Dimensions : {df.shape[0]} lignes × {df.shape[1]} colonnes")
        print(f"   📋 Colonnes : {list(df.columns)}")
        
        return df


# Cellule 3 : Exécution
if __name__ == "__main__":
    generator = AdvancedDatasetGenerator('GenRules_v2.json')
    df = generator.generate()
    
    # Aperçu du dataset
    print("\n📋 Aperçu des 5 premières lignes :")
    display(df.head())
    
    print("\n📊 Statistiques descriptives :")
    display(df.describe())
